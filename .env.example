# Monolith MCP -- environment template
# Copy this file to .env and set values as needed. Do not commit .env.

# === Core MCP Server ===
# Path to ONNX Runtime shared library (.so/.dll). Enables Nomic embeddings; unset = FTS-only.
ORT_DYLIB_PATH=./lib/libonnxruntime.so.1.23.0
# Local data directory (RAG DB, manifest, models). Default: ./data
DATA_DIR=./data
# Comma-separated paths for ingest, refresh_file_index, get_file_history. Default: cwd
ALLOWED_ROOTS=.

# === Model Routing (Multi-Agent Pipeline) ===
# Gemini Free Tier (get key at https://aistudio.google.com/apikey)
GOOGLE_API_KEY=
# Anthropic (optional, for Claude API direct calls)
ANTHROPIC_API_KEY=
# OpenAI (optional, for GPT fallback)
OPENAI_API_KEY=

# === Ollama (Local Models) ===
# Ollama endpoint (hardcoded to http://localhost:11434 in model_routing)
# Ensure Ollama is running locally for local model routing.

# === Vault / Paths ===
# When set, RAG DB and training live here (vault mode).
# VAULT_DIR=
# HOLLOW_VAULT=
# Single workspace root when vault set; used if ALLOWED_ROOTS unset.
# PRISM_ROOT=
# When set, auto_approve_pattern and training write here (e.g. .prism).
# GOLDEN_SET_DIR=

# === Tool Paths ===
# Path for get_tool_selection_guide; else first allowed root docs/TOOL_SELECTION_GUIDE.md.
# TOOL_SELECTION_GUIDE_PATH=
# Dir for get_design_tokens; else first allowed root docs/design/data.
# DESIGN_TOKENS_DIR=
# When set, compile_rules reads global rules from this dir.
# RULES_VAULT=
# GLOBAL_RULES_DIR=

# === Control Loop ===
# MCP_MAX_LOOP_ITERATIONS=20
# MCP_STAGNATION_THRESHOLD=3
# MCP_CONVERGENCE_THRESHOLD=0.95
# MCP_DEAD_END_THRESHOLD=2

# === Model Route Overrides (optional) ===
# Override which model handles each control loop phase (claude/gemini/local).
# MCP_ROUTE_PLANNING=claude
# MCP_ROUTE_EXECUTION=gemini
# MCP_ROUTE_REVIEW=gemini
# MCP_ROUTE_AUDIT=local
# MCP_ROUTE_RECOVERY=claude

# === Tool Guardrails ===
# Set to 1 to make all tools read-only (no writes).
# MCP_READ_ONLY=0
# Set to 1 to expose all 43+ tools (default: minimal 5-tool set for token savings).
# MCP_FULL_TOOLS=0
# Set to 1 to disable loop guard (blocks same tool+args after N calls).
# MCP_LOOP_GUARD_DISABLED=0
# Number of identical calls before loop guard blocks (default: 5).
# MCP_LOOP_GUARD_THRESHOLD=5
# Max tool calls per session before hard stop.
# MCP_MAX_TOOL_CALLS_PER_SESSION=
# Path for tool audit log (JSON lines).
# MCP_AUDIT_LOG_PATH=

# === Janitor ===
JANITOR_INTERVAL_HOURS=24
JANITOR_WEB_PRUNE_DAYS=30
JANITOR_TRIM_KEEP_LAST=100000
JANITOR_REVIEW_LESSONS_DAYS=7

# === Limits ===
RAG_MAX_RESPONSE_CHARS=32000
EXECUTE_SHELL_MAX_OUTPUT_CHARS=16000
EXECUTE_SHELL_TIMEOUT_SECS=120
# Comma-separated program names (e.g. cargo,git,grep,ls,npm). Unset = built-in list.
# EXECUTE_SHELL_ALLOWLIST=

# === Search / Reranking ===
# RERANK_TOP_K=
# RERANK_CANDIDATES=

# === Web / Research ===
# FETCH_WEB_MAX_CHARS=32000

# === Semantic Cache ===
# SEMANTIC_CACHE_ENABLED=0

# === Integrations ===
# search_web: Tavily or Serper API key (at least one needed for search_web).
# TAVILY_API_KEY=
# SERPER_API_KEY=

# === Webhooks (optional) ===
# SLACK_WEBHOOK_URL_EVOLUTION=
# SLACK_WEBHOOK_URL_LOG=

# === Observability ===
# RUST_LOG=info
# OTEL_EXPORTER_OTLP_ENDPOINT=
